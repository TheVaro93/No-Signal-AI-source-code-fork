# Copy this file to .env and fill in your values

# Get your free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: change the model (default: llama-3.3-70b-versatile)
# Other good options: llama3-8b-8192, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# Port for the local server
PORT=3000

# In production: set this to your GitHub Pages URL to restrict CORS
# Example: https://yugos06.github.io
ALLOWED_ORIGIN=*
