# Copy this file to .env and fill in your values

# Get your free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: change the model (default: llama-3.3-70b-versatile)
# Other good options: llama3-8b-8192, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# Port for the local server
PORT=3000

# Allowed CORS origins (comma-separated). Leave empty to allow any origin.
ALLOWED_ORIGIN=https://your-frontend-domain.com

# Signed URL TTL for private uploads (seconds)
UPLOAD_URL_TTL_SECONDS=3600

# Supabase project credentials
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe (optional — for subscription support page)
# Create a product + price at https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...

# Google Gemini API (optional — for STELLAR model)
# Get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Dev accounts (max 3 emails, comma-separated)
DEV_EMAILS=dev1@example.com,dev2@example.com
